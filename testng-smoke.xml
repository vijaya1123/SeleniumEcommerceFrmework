<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" parallel="methods" thread-count="2" verbose="1">

    <!-- Listeners -->
    <listeners>
        <listener class-name="com.seleniumui.framework.listeners.TestListener"/>
        <listener class-name="com.seleniumui.framework.listeners.AnnotationTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.seleniumui.framework.tests.LoginTest"/>
     
        </classes>
    </test>

</suite>

