<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Execution Suite" parallel="methods" thread-count="4" verbose="1">

    <!-- Listeners -->
    <listeners>
        <listener class-name="com.seleniumui.framework.listeners.TestListener"/>
        <listener class-name="com.seleniumui.framework.listeners.AnnotationTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Parallel Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.seleniumui.framework.tests.LoginTest"/>
            <class name="com.seleniumui.framework.tests.ProductTest"/>
            <class name="com.seleniumui.framework.tests.CheckoutTest"/>
            <class name="com.seleniumui.framework.tests.SessionTest"/>
        </classes>
    </test>

</suite>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Automation Suite" parallel="tests" thread-count="3" verbose="1">

    <!-- Listeners -->
    <listeners>
        <listener class-name="com.seleniumui.framework.listeners.TestListener"/>
        <listener class-name="com.seleniumui.framework.listeners.AnnotationTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Smoke Test Suite -->
    <test name="Smoke Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.seleniumui.framework.tests.LoginTest"/>
            <class name="com.seleniumui.framework.tests.ProductTest"/>
            <class name="com.seleniumui.framework.tests.CheckoutTest"/>
            <class name="com.seleniumui.framework.tests.SessionTest"/>
        </classes>
    </test>

    <!-- Regression Test Suite - Chrome -->
    <test name="Regression Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.seleniumui.framework.tests.LoginTest"/>
            <class name="com.seleniumui.framework.tests.ProductTest"/>
            <class name="com.seleniumui.framework.tests.CheckoutTest"/>
            <class name="com.seleniumui.framework.tests.SessionTest"/>
        </classes>
    </test>

    <!-- Regression Test Suite - Edge -->
    <test name="Regression Tests - Edge">
        <parameter name="browser" value="edge"/>
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.seleniumui.framework.tests.LoginTest"/>
            <class name="com.seleniumui.framework.tests.ProductTest"/>
            <class name="com.seleniumui.framework.tests.CheckoutTest"/>
            <class name="com.seleniumui.framework.tests.SessionTest"/>
        </classes>
    </test>

</suite>

